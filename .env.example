# Variáveis de ambiente para desenvolvimento local
# Para rodar com Docker Compose, estas variáveis são definidas no docker-compose.yml

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=unicred_voting
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Validação de CPF
# VOTER_VALIDATION_URL é a API externa do Heroku
VOTER_VALIDATION_URL=https://user-info.herokuapp.com
# false = apenas validação matemática local (padrão seguro)
# true  = valida localmente + consulta API externa (fail-open em falha de rede)
VOTER_VALIDATION_ENABLED=false

SESSION_CLOSE_INTERVAL_SECONDS=30
DEBUG=false
